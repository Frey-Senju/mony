{
  "language": "portuguese",
  "toolPreferences": {
    "preferredShell": "bash",
    "displayFormat": "concise"
  },
  "mcpServers": {
    "obsidian": {
      "command": "obsidian-mcp",
      "env": {
        "OBSIDIAN_VAULT_PATH": "/c/Users/cristofer.schwartzer/Desktop/Obsidian",
        "OBSIDIAN_API_KEY": "d8edac1e2822cb0e6afc8e9883c49a6116c4e1572bf10815af83966f3ae20049"
      }
    }
  },
  "hooks": {
    "PostCompact": [
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.summary // empty' | { read -r summary; if [ -n \"$summary\" ]; then echo \"## Session $(date +%Y-%m-%d\\ %H:%M:%S)\\n\\n$summary\" >> /c/Users/cristofer.schwartzer/Desktop/Obsidian/Mony/SESSIONS.md; fi; }",
            "timeout": 10,
            "statusMessage": "Salvando sumário em Obsidian..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "UserPromptSubmit",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"📚 Consultando Obsidian vault...\"}'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
