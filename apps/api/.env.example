DATABASE_URL=postgresql://user:password@localhost:5432/mony_dev
JWT_SECRET=your-secret-key-here
ENVIRONMENT=development

# Open Finance — consent + sync
ENCRYPTION_KEY=your-fernet-key-here  # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
OPEN_FINANCE_CALLBACK_URL=http://localhost:8000/open-finance/consent/callback
FRONTEND_URL=http://localhost:3000

# Open Finance — Story 2.2 sync pipeline
REDIS_URL=redis://localhost:6379/0
WEBHOOK_SECRET=your-hmac-secret-here   # 32+ random bytes; verifies HMAC-SHA256 on /open-finance/webhook
OF_SYNC_LOOKBACK_DAYS=7                # Default lookback for incremental syncs
OF_FIRST_SYNC_LOOKBACK_DAYS=90         # Lookback for first-ever sync per linked account
OF_SYNC_USE_STUB=0                     # 1 to bypass the bank API and use deterministic stub data
CELERY_TASK_ALWAYS_EAGER=0             # 1 to run tasks inline (no broker) — useful for tests/dev
